{
  "$description": "Heimdall — canonical W3C DTCG design tokens (target: tui). Single edit surface; the design-system-author emits terminal-theme.json from this file. Colour $values mirror docs/design/identity/palette.json (the annotated colour source of record). The default color.* group is the DARK theme (primary); color.light.* mirrors it for light terminals. Spacing is in terminal cells; borders map to box-drawing sets / lipgloss presets; type and status tokens compose colour references with SGR attributes and glyphs so meaning never depends on colour alone.",
  "_meta": {
    "name": "Heimdall",
    "target": "tui",
    "format": "W3C DTCG",
    "status": "approved",
    "approved_by": null,
    "approved_at": null,
    "default_theme": "dark",
    "custom_types": {
      "terminalStyle": "object $value: { color: <ref>, attributes: [SGR names], glyph?: <string> }",
      "terminalStatus": "object $value: { color: <ref>, glyph: <string>, label: <string>, emphasis: [SGR names] }"
    }
  },
  "color": {
    "$type": "color",
    "neutral": {
      "$description": "10-step neutral ramp, aligned to ANSI-256 greys (near-white -> near-black).",
      "0": {
        "$value": "#eeeeee",
        "$description": "ansi 255"
      },
      "1": {
        "$value": "#d0d0d0",
        "$description": "ansi 252"
      },
      "2": {
        "$value": "#a8a8a8",
        "$description": "ansi 248"
      },
      "3": {
        "$value": "#949494",
        "$description": "ansi 246"
      },
      "4": {
        "$value": "#767676",
        "$description": "ansi 243"
      },
      "5": {
        "$value": "#585858",
        "$description": "ansi 240"
      },
      "6": {
        "$value": "#444444",
        "$description": "ansi 238"
      },
      "7": {
        "$value": "#303030",
        "$description": "ansi 236"
      },
      "8": {
        "$value": "#1c1c1c",
        "$description": "ansi 234"
      },
      "9": {
        "$value": "#121212",
        "$description": "ansi 233"
      }
    },
    "bg": {
      "$description": "Dark theme surfaces.",
      "base": {
        "$value": "{color.neutral.9}",
        "$description": "app background — ansi 233"
      },
      "panel": {
        "$value": "{color.neutral.8}",
        "$description": "elevated panel — ansi 234"
      },
      "selection": {
        "$value": "{color.neutral.7}",
        "$description": "active row — ansi 236"
      },
      "shadow": {
        "$value": "#080808",
        "$description": "depth-panel shadow — ansi 232"
      }
    },
    "fg": {
      "$description": "Dark theme foreground text.",
      "primary": {
        "$value": "{color.neutral.0}",
        "$description": "primary text + values — ansi 255"
      },
      "secondary": {
        "$value": "#c6c6c6",
        "$description": "secondary text — ansi 251"
      },
      "muted": {
        "$value": "{color.neutral.3}",
        "$description": "muted text (solid AA colour, not the dim attribute) — ansi 246"
      }
    },
    "hue": {
      "$description": "Dark theme semantic hue primitives.",
      "ok": {
        "$value": "#5fd75f",
        "$description": "success / online — ansi 77"
      },
      "caution": {
        "$value": "#ffaf00",
        "$description": "degraded / transitional — ansi 214"
      },
      "stale": {
        "$value": "#d7af87",
        "$description": "stale / aging — ansi 180"
      },
      "absence": {
        "$value": "#a8a8a8",
        "$description": "offline / absent / n-a — ansi 248"
      },
      "critical": {
        "$value": "#ff5f5f",
        "$description": "error / refused — ansi 203"
      },
      "info": {
        "$value": "#5fd7ff",
        "$description": "info / relay / needs-helper — ansi 81"
      }
    },
    "severity": {
      "$description": "Dark gauge-fill ramp, cool -> warm (low -> high utilisation/temperature).",
      "1": {
        "$value": "#5fd7af",
        "$description": "nominal 0-39% — ansi 79"
      },
      "2": {
        "$value": "#87d75f",
        "$description": "moderate 40-59% — ansi 113"
      },
      "3": {
        "$value": "#ffd75f",
        "$description": "elevated 60-74% — ansi 221"
      },
      "4": {
        "$value": "#ff875f",
        "$description": "high 75-89% — ansi 209"
      },
      "5": {
        "$value": "#ff5f5f",
        "$description": "critical 90-100% — ansi 203"
      }
    },
    "state": {
      "$description": "Dark semantic colour aliases (reference hue / signature primitives).",
      "online": {
        "$value": "{color.hue.ok}"
      },
      "degraded": {
        "$value": "{color.hue.caution}"
      },
      "stale": {
        "$value": "{color.hue.stale}"
      },
      "offline": {
        "$value": "{color.hue.absence}"
      },
      "error": {
        "$value": "{color.hue.critical}"
      },
      "info": {
        "$value": "{color.hue.info}"
      },
      "focus": {
        "$value": "{color.signature}"
      }
    },
    "light": {
      "$description": "Light terminal theme mirror. Darkened so every pair clears AA on white.",
      "bg": {
        "base": {
          "$value": "#ffffff",
          "$description": "app background — ansi 231"
        },
        "panel": {
          "$value": "#eeeeee",
          "$description": "elevated panel — ansi 255"
        },
        "selection": {
          "$value": "#d0d0d0",
          "$description": "active row — ansi 252"
        },
        "shadow": {
          "$value": "#bcbcbc",
          "$description": "depth shadow — ansi 250"
        }
      },
      "fg": {
        "primary": {
          "$value": "#1c1c1c",
          "$description": "primary text — ansi 234"
        },
        "secondary": {
          "$value": "#3a3a3a",
          "$description": "secondary text — ansi 237"
        },
        "muted": {
          "$value": "#626262",
          "$description": "muted text — ansi 241"
        }
      },
      "hue": {
        "ok": {
          "$value": "#006d00",
          "$description": "ansi 22"
        },
        "caution": {
          "$value": "#9c5400",
          "$description": "ansi 130"
        },
        "stale": {
          "$value": "#6b5526",
          "$description": "ansi 58"
        },
        "absence": {
          "$value": "#626262",
          "$description": "ansi 241"
        },
        "critical": {
          "$value": "#c81414",
          "$description": "ansi 160"
        },
        "info": {
          "$value": "#005f87",
          "$description": "ansi 24"
        }
      },
      "severity": {
        "1": {
          "$value": "#006d00",
          "$description": "nominal — ansi 22"
        },
        "2": {
          "$value": "#5a7400",
          "$description": "moderate — ansi 64"
        },
        "3": {
          "$value": "#806600",
          "$description": "elevated — ansi 94"
        },
        "4": {
          "$value": "#9c5400",
          "$description": "high — ansi 130"
        },
        "5": {
          "$value": "#c81414",
          "$description": "critical — ansi 160"
        }
      },
      "state": {
        "online": {
          "$value": "{color.light.hue.ok}"
        },
        "degraded": {
          "$value": "{color.light.hue.caution}"
        },
        "stale": {
          "$value": "{color.light.hue.stale}"
        },
        "offline": {
          "$value": "{color.light.hue.absence}"
        },
        "error": {
          "$value": "{color.light.hue.critical}"
        },
        "info": {
          "$value": "{color.light.hue.info}"
        },
        "focus": {
          "$value": "{color.light.signature}"
        }
      },
      "signature": {
        "$value": "#005f87",
        "$description": "electric-blue signature (light) — ansi 24"
      },
      "steel": {
        "$value": "#1c1c1c",
        "$description": "steel wordmark (light) — ansi 234"
      },
      "border": {
        "$value": "#626262",
        "$description": "panel + chrome border, unfocused (light) — ansi 241. UI element at 6.1:1 on background / 5.26:1 on panel (>= 3:1). Focused border uses {color.light.signature}."
      }
    },
    "signature": {
      "$value": "#00d7ff",
      "$description": "electric-blue signature — Heimdall's eye / focus accent — ansi 45"
    },
    "steel": {
      "$value": "#d0d0d0",
      "$description": "steel/silver wordmark — ansi 252"
    },
    "border": {
      "$value": "{color.neutral.4}",
      "$description": "panel + chrome border, unfocused — #767676 / ansi 243. UI element held to the 3:1 large/UI bar: 4.12:1 on background, 3.75:1 on panel. The emitter MUST source structure.border.fg from this token; do NOT hard-code neutral.5 (#585858 = 2.63:1, FAILS AA). Focused border uses {color.signature}."
    }
  },
  "space": {
    "$type": "number",
    "$description": "Spacing in terminal cells (columns for horizontal padding/gap, rows for vertical). lipgloss Padding/Margin take cell integers.",
    "0": {
      "$value": 0,
      "$description": "flush"
    },
    "1": {
      "$value": 1,
      "$description": "tight gutter / inter-column gap"
    },
    "2": {
      "$value": 2,
      "$description": "standard panel padding"
    },
    "3": {
      "$value": 3,
      "$description": "comfortable padding"
    },
    "4": {
      "$value": 4,
      "$description": "section separation"
    },
    "6": {
      "$value": 6,
      "$description": "large separation"
    },
    "8": {
      "$value": 8,
      "$description": "page-level separation"
    }
  },
  "border": {
    "$type": "string",
    "$description": "Box-drawing border styles. $value names the lipgloss preset; $extensions['com.heimdall.tui'].glyphs lists the characters; 'ascii' is the TERM=dumb / NO_COLOR fallback.",
    "app": {
      "$value": "double",
      "$extensions": {
        "com.heimdall.tui": {
          "lipgloss": "DoubleBorder",
          "glyphs": {
            "topLeft": "╔",
            "top": "═",
            "topRight": "╗",
            "left": "║",
            "right": "║",
            "bottomLeft": "╚",
            "bottom": "═",
            "bottomRight": "╝"
          }
        }
      }
    },
    "panel": {
      "$value": "single",
      "$extensions": {
        "com.heimdall.tui": {
          "lipgloss": "NormalBorder",
          "glyphs": {
            "topLeft": "┌",
            "top": "─",
            "topRight": "┐",
            "left": "│",
            "right": "│",
            "bottomLeft": "└",
            "bottom": "─",
            "bottomRight": "┘"
          }
        }
      }
    },
    "panelRounded": {
      "$value": "rounded",
      "$extensions": {
        "com.heimdall.tui": {
          "lipgloss": "RoundedBorder",
          "glyphs": {
            "topLeft": "╭",
            "top": "─",
            "topRight": "╮",
            "left": "│",
            "right": "│",
            "bottomLeft": "╰",
            "bottom": "─",
            "bottomRight": "╯"
          }
        }
      }
    },
    "depth": {
      "$value": "thick",
      "$extensions": {
        "com.heimdall.tui": {
          "lipgloss": "ThickBorder",
          "glyphs": {
            "topLeft": "┏",
            "top": "━",
            "topRight": "┓",
            "left": "┃",
            "right": "┃",
            "bottomLeft": "┗",
            "bottom": "━",
            "bottomRight": "┛"
          },
          "note": "high-fidelity depth panel only"
        }
      }
    },
    "ascii": {
      "$value": "ascii",
      "$extensions": {
        "com.heimdall.tui": {
          "lipgloss": "Border{...}",
          "glyphs": {
            "topLeft": "+",
            "top": "-",
            "topRight": "+",
            "left": "|",
            "right": "|",
            "bottomLeft": "+",
            "bottom": "-",
            "bottomRight": "+"
          },
          "note": "degraded / dumb-terminal fallback"
        }
      }
    }
  },
  "type": {
    "$type": "terminalStyle",
    "$description": "Type roles: colour reference + SGR attribute list (+ optional leading glyph). No font families or sizes — a TUI renders one monospace cell grid.",
    "title": {
      "$value": {
        "color": "{color.steel}",
        "attributes": [
          "bold"
        ],
        "glyph": "⬢"
      }
    },
    "heading": {
      "$value": {
        "color": "{color.fg.primary}",
        "attributes": [
          "bold"
        ]
      }
    },
    "subheading": {
      "$value": {
        "color": "{color.fg.secondary}",
        "attributes": [
          "bold"
        ]
      }
    },
    "label": {
      "$value": {
        "color": "{color.fg.muted}",
        "attributes": [
          "faint"
        ]
      }
    },
    "body": {
      "$value": {
        "color": "{color.fg.primary}",
        "attributes": []
      }
    },
    "value": {
      "$value": {
        "color": "{color.fg.primary}",
        "attributes": [
          "bold"
        ]
      }
    },
    "unit": {
      "$value": {
        "color": "{color.fg.muted}",
        "attributes": []
      }
    },
    "muted": {
      "$value": {
        "color": "{color.fg.muted}",
        "attributes": []
      }
    },
    "caption": {
      "$value": {
        "color": "{color.fg.muted}",
        "attributes": [
          "italic"
        ],
        "italicFallback": "faint"
      }
    },
    "keybinding": {
      "$value": {
        "color": "{color.fg.primary}",
        "attributes": [
          "underline",
          "bold"
        ]
      }
    },
    "inputActive": {
      "$value": {
        "color": "{color.fg.primary}",
        "attributes": [
          "underline"
        ],
        "glyph": "▏"
      }
    },
    "focus": {
      "$value": {
        "color": "{color.signature}",
        "attributes": [
          "reverse"
        ],
        "glyph": "▸"
      }
    }
  },
  "status": {
    "$type": "terminalStatus",
    "$description": "One composite token per wireframe state: colour reference + glyph + word + emphasis. The glyph and word are the meaning carriers; colour is reinforcement; emphasis is an SGR attribute. NO_COLOR-safe by construction.",
    "online": {
      "$value": {
        "color": "{color.state.online}",
        "glyph": "●",
        "label": "ONLINE",
        "emphasis": []
      }
    },
    "degraded": {
      "$value": {
        "color": "{color.state.degraded}",
        "glyph": "◐",
        "label": "DEGRADED",
        "emphasis": []
      }
    },
    "enrolling": {
      "$value": {
        "color": "{color.state.degraded}",
        "glyph": "◐",
        "label": "ENROLLING…",
        "emphasis": []
      }
    },
    "offline": {
      "$value": {
        "color": "{color.state.offline}",
        "glyph": "○",
        "label": "OFFLINE",
        "emphasis": []
      }
    },
    "stale": {
      "$value": {
        "color": "{color.state.stale}",
        "glyph": "⏱",
        "label": "STALE",
        "emphasis": [
          "faint"
        ]
      }
    },
    "error": {
      "$value": {
        "color": "{color.state.error}",
        "glyph": "⚠",
        "label": "ERROR",
        "emphasis": [
          "bold"
        ]
      }
    },
    "needsHelper": {
      "$value": {
        "color": "{color.state.info}",
        "glyph": "⚿",
        "label": "needs helper",
        "emphasis": []
      }
    },
    "unavailable": {
      "$value": {
        "color": "{color.state.offline}",
        "glyph": "—",
        "label": "unavailable",
        "emphasis": [
          "faint"
        ]
      }
    },
    "installed": {
      "$value": {
        "color": "{color.state.online}",
        "glyph": "✓",
        "label": "installed",
        "emphasis": []
      }
    },
    "absent": {
      "$value": {
        "color": "{color.state.offline}",
        "glyph": "–",
        "label": "absent",
        "emphasis": [
          "faint"
        ]
      }
    },
    "relaying": {
      "$value": {
        "color": "{color.state.info}",
        "glyph": "↑",
        "label": "relaying",
        "emphasis": []
      }
    },
    "reconnecting": {
      "$value": {
        "color": "{color.state.degraded}",
        "glyph": "↯",
        "label": "reconnecting",
        "emphasis": []
      }
    },
    "rateLimited": {
      "$value": {
        "color": "{color.state.degraded}",
        "glyph": "⚡",
        "label": "rate-limited",
        "emphasis": []
      }
    },
    "refused": {
      "$value": {
        "color": "{color.state.error}",
        "glyph": "✋",
        "label": "refused",
        "emphasis": [
          "bold"
        ]
      }
    },
    "focus": {
      "$value": {
        "color": "{color.state.focus}",
        "glyph": "▸",
        "label": "focus",
        "emphasis": [
          "reverse"
        ]
      }
    }
  }
}