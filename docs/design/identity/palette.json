{
  "_meta": {
    "name": "Heimdall",
    "tagline": "watch over all realms",
    "target": "tui",
    "status": "approved",
    "approved_by": null,
    "approved_at": null,
    "default_theme": "dark",
    "color_model": "truecolor (24-bit) hex, primary; nearest ANSI-256 index recorded per color as the 256-colour fallback",
    "wcag": "2.2 AA — every text pair >= 4.5:1, every large/UI pair (gauge blocks, focus, borders) >= 3:1. All pairs verified; see README contrast table.",
    "concept": "Heimdall watches over all realms. The wordmark is steel/silver; the single signature accent is the electric blue of Heimdall's all-seeing eye (also the Bifrost glow), used for title rule, focus and brand marks. The rainbow bridge is expressed functionally as the severity ramp (cool -> warm). Backgrounds sit near-black so monitoring data carries the contrast.",
    "color_only_signaling": "Colour never carries meaning alone. Every state is glyph + text (+ numeric value / timestamp where relevant); see state_glyph_legend. Focus additionally uses reverse video and a leading marker.",
    "no_color_behavior": "Under NO_COLOR / TERM=dumb / monochrome the palette collapses to the terminal's default fg/bg. Meaning survives via: (1) status glyph, (2) status word, (3) numeric value, (4) gauge block density (░▒▓█), (5) reverse video for focus. No information is lost — this is the accessible baseline render described in wireframe 0004."
  },
