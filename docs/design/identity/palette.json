  "state_glyph_legend": {
    "_doc": "Canonical map of the wireframe legend (stories 0001-0011). glyph + label are the meaning carriers; colorRole points at themes.<theme>.semantic.<role>; emphasis names an extra SGR attribute applied by typography.json.",
    "online": {
      "glyph": "●",
      "label": "online / ok",
      "colorRole": "online",
      "emphasis": null
    },
    "degraded": {
      "glyph": "◐",
      "label": "degraded / enrolling",
      "colorRole": "degraded",
      "emphasis": null
