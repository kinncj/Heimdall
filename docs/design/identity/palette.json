      "severity": {
        "_doc": "Sequential low->high gauge-fill ramp (cool -> warm) for utilisation / temperature. A full gauge reads hot/busy. Applied to the filled blocks of █▓▒░ gauges and sparklines. Distinct in ANSI-256; monochrome fallback = block density + printed numeric value.",
        "thresholds": {
          "nominal": "0-39%",
          "moderate": "40-59%",
          "elevated": "60-74%",
          "high": "75-89%",
          "critical": "90-100%",
          "temp_note": "temperature uses analogous °C bands defined per adapter"
        },
