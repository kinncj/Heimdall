# Template project .gitignore
# This file is copied into every project scaffolded by maple init.

# Dependencies
node_modules/
.pnp/
.pnp.js

# Build output
dist/
build/
out/
bin/
.next/
.nuxt/
.output/

# Test output
coverage/
.nyc_output/
playwright-report/
test-results/

# Environment & secrets
.env
.env.local
.env.*.local
*.pem
*.key

# Docker
*.log

# macOS
.DS_Store
.AppleDouble

# Editor artefacts
.idea/
.vscode/
*.swp
*.swo
*~

# Claude Code local settings and runtime state
.claude/settings.local.json
.claude/logs/
.claude/pending-sync.jsonl
.claude/state/

# MAPLE CLI state (if maple is installed inside the project)
.maple.json

# Local development TLS certificates (generated by make dev-certs)
certs/
# ai-squad tool repo — root .gitignore

# CLI runtime state (jingle flag + last-used options)
.ai-squad.json

# Node
node_modules/
npm-debug.log*

# macOS
.DS_Store
.AppleDouble
.LSOverride

# Editor artefacts
.idea/
.vscode/
*.swp
*.swo
*~

# Test artefacts
/tmp/

# Claude Code local settings (generated at runtime, not template content)
# Leading / anchors to repo root so template/.claude/settings.local.json is unaffected
/.claude/settings.local.json
var/*

# Swarm v2 session data (worktrees, status files, result.md)
.swarm/squad
maple
.maple.json

# Dogfood runtime state — generated at runtime, holds maple.json + portal token, never commit
/.claude/state/
/.claude/logs/
/.opencode/state/
/.cursor/state/
__pycache__/

# Build artifact — tui/template is a copy of ./template for go:embed, never commit it
tui/template/
# Stale leftover from running maple init inside this repo's template/ dir
template/template/
.playwright-mcp/
SESSION_SUMMARY.md

# Generated documentation screenshots (regenerate with `make screenshots`).
# The trimmed PNGs under img/ ARE committed — they're embedded in the README and
# guides, which GitHub renders. The intermediate ANSI/HTML and the GIFs are not.
/docs/screenshots/ansi/
/docs/screenshots/html/
/docs/screenshots/gif/
