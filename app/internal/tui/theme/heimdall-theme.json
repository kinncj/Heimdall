    "brand_mark": "⬢",
    "spinner_braille": [
      "⠹",
      "⠸",
      "⠼"
    ],
    "gauge_blocks": [
      "█",
      "▓",
      "▒",
      "░"
    ],
    "sparkline": [
      "▁",
      "▂",
      "▃",
      "▄",
      "▅",
      "▆",
      "▇",
      "█"
    ],
    "trend": {
      "rising": "↑",
      "steady": "→",
      "falling": "↓"
    },
    "ascii_fallback": {
      "gauge_fill": "#",
      "gauge_track": " ",
      "trend_up": "^",
      "trend_steady": "="
    }
  },
  "borders": {
