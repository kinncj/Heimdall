{
  "name": "heimdall",
  "target": "tui",
  "default_mode": "dark",
  "source": "docs/design/identity/tokens.json",
  "mono_fallback": "Under NO_COLOR/TERM=dumb/monochrome, colours collapse to terminal default fg/bg. Meaning survives via glyph, status word, numeric value, gauge block density (░▒▓█) and reverse video for focus.",
